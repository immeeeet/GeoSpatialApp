# ── PostGIS ──────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=geospatial
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# ── API Keys ─────────────────────────────────────────────────
# OpenRouteService — sign up at https://openrouteservice.org/
ORS_API_KEY=your_ors_api_key_here

# Overpass API (default public instance, no key needed)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# ── Raster Dataset Paths ─────────────────────────────────────
# Absolute paths to GeoTIFF files
GHSL_RASTER_PATH=datasets/ghsl_2025.tif
VIIRS_RASTER_PATH=datasets/viirs_nightlights.tif

# ── ML Model ─────────────────────────────────────────────────
MODEL_PATH=backend/ml_engine/models/best_model.pkl

# ── Server ───────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=False
